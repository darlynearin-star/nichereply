# ─────────────────────────────────────────────
# NicheReply Environment Configuration
# ─────────────────────────────────────────────
# 1. Go to https://supabase.com → Create a project
# 2. Copy these values from Project Settings → API
# ─────────────────────────────────────────────

NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─────────────────────────────────────────────
# WhatsApp Cloud API
# 1. Go to https://developers.facebook.com
# 2. Create a WhatsApp Business App
# 3. Get your Phone Number ID and Access Token
# ─────────────────────────────────────────────

WA_PHONE_NUMBER_ID=your_whatsapp_phone_number_id
WA_ACCESS_TOKEN=your_whatsapp_access_token
WA_WEBHOOK_VERIFY_TOKEN=nichereply_verify_2024
WA_API_VERSION=v21.0

# ─────────────────────────────────────────────
# App URL (change in production)
# ─────────────────────────────────────────────

NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─────────────────────────────────────────────
# Cron job secret (for /api/cron/reminders)
# ─────────────────────────────────────────────

CRON_SECRET=your-cron-secret-change-this
